# Supabase Database Configuration
# Get this from Supabase Dashboard → Settings → Database → Connection string
# Use the "Connection pooling" URL for production
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?sslmode=require"

# Microsoft Authentication (Azure Active Directory)
VITE_MICROSOFT_CLIENT_ID="your-microsoft-client-id"
VITE_MICROSOFT_AUTHORITY="https://login.microsoftonline.com/common"

# Optional: For specific tenant authentication
# VITE_MICROSOFT_AUTHORITY="https://login.microsoftonline.com/your-tenant-id"

# Development Database
PGDATABASE=
PGHOST=
PGPASSWORD=
PGPORT=
PGUSER=